# See datadog-files/README.md for rationale.

#include <tunables/global>

profile usr.bin.kata-agent /usr/bin/kata-agent flags=(attach_disconnected) {
  capability,
  network,
  mount,
  remount,
  umount,
  pivot_root,
  ptrace,
  signal,
  dbus,

  /{,**} rwklm,
  /** Px -> kata-container,

  deny /run/kata-containers/shared/containers/*/datadog-agent/auth/**  rwklmx,
  deny /proc/*/root/run/kata-containers/shared/containers/*/datadog-agent/auth/** rwklmx,
}
