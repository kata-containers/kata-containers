# /etc/systemd/system/guest-services-imagepull.service
[Unit]
Description=Guest Components Image Pull Service
Documentation=https://github.com/kata-containers/kata-containers
PartOf=guest-services.target
Requires=initdata-processor.service
After=initdata-processor.service

[Service]
Type=simple
ExecStart=/usr/bin/guest-services image-pull --socket /run/guest-services/imagepull.sock
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
User=root
Group=root

# Socket configuration
RuntimeDirectory=guest-services
RuntimeDirectoryMode=0755

[Install]
WantedBy=guest-services.target
