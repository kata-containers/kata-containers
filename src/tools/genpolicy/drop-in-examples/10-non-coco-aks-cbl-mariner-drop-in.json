        "source": "shm"
      },
      {
        "driver": "virtio-fs",
        "driver_options": [],
        "fs_group": null,
        "fstype": "virtiofs",
        "mount_point": "/run/kata-containers/shared/containers/",
        "options": [],
        "source": "kataShared"
      }
    ]
  },
  {
    "op": "replace",
    "path": "/volumes/configMap/driver",
    "value": "watchable-bind"
  },
  {
    "op": "replace",
    "path": "/volumes/configMap/mount_point",
    "value": "^$(cpath)/watchable/$(bundle-id)-[a-z0-9]{16}-"
